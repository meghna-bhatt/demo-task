{% stylesheet %}
  .featured-collection {
    padding: 60px 0;
    background-color: #fafafa;
  }
  .featured-collection-header {
    text-align: center;
    margin-bottom: 50px;
  }
  .featured-collection-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 15px;
    color: #333;
  }
  .featured-collection-description {
    font-size: 1.1rem;
    color: #666;
    max-width: 600px;
    margin: 0 auto;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    margin-bottom: 40px;
  }
  .product-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 12px;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    background-color: #ffffff;
    text-align: left;
  }
  .product-card:hover {
    border-color: #d1d5db;
  }
  .product-image {
    width: 100%;
    aspect-ratio: 4 / 2;
    overflow: hidden;
    border-radius: 6px;
    margin-bottom: 10px;
    background-color: #fcfdff;
  }
  .product-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .product-info {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1 1 auto;
    padding: 0;
  }

  .view-all-btn {
    text-align: center;
  }
  .view-all-btn a {
    background: linear-gradient(135deg, #28a745 0%, #1e7e34 100%);
    color: white;
    padding: 15px 40px;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    display: inline-block;
    transition: background 0.3s ease;
    box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
  }
  .view-all-btn a:hover {
    background: linear-gradient(135deg, #1e7e34 0%, #145c27 100%);
  }
  @media (max-width: 1024px) {
    .products-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 25px;
    }
  }
  @media (max-width: 768px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
    .featured-collection {
      padding: 40px 0;
    }
    .featured-collection-title {
      font-size: 2rem;
    }
  }
  @media (max-width: 480px) {
    .products-grid {
      grid-template-columns: 1fr;
      gap: 15px;
    }
    .featured-collection-title {
      font-size: 1.75rem;
    }
  }
{% endstylesheet %}

<section class="featured-collection">
  <div class="container">
    <div class="featured-collection-header">
      <h2 class="featured-collection-title">{{ section.settings.collection_title }}</h2>
      {% if section.settings.collection_description %}
        <p class="featured-collection-description">{{ section.settings.collection_description }}</p>
      {% endif %}
    </div>

    {% if section.settings.collection != blank %}
      {% assign collection = collections[section.settings.collection] %}
      
      {% if collection.products.size > 0 %}
        <div class="products-grid">
          {% for product in collection.products limit: section.settings.products_limit %}
            <div class="product-card">
              <a class="product-image" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                <img
                  src="{{ product.featured_image | image_url: width: 400 }}"
                  alt="{{ product.title | escape }}"
                  width="400"
                  height="300"
                  loading="lazy"
                  decoding="async"
                >
              </a>
              <div class="product-info">
                <h3 class="product-name">
                  <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>
                <p class="product-price">{{ product.price | money }}</p>
                <a class="btn" href="{{ product.url }}" title="View Product">View Product</a>
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="view-all-btn">
          <a href="{{ collection.url }}" title="View All Products">View All Products</a>
        </div>
      {% else %}
        <p>No products found in this collection.</p>
      {% endif %}
    {% else %}
      <p>Please select a collection to display.</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "collection_title",
      "label": "Section Title",
      "default": "Featured Collection"
    },
    {
      "type": "textarea",
      "id": "collection_description",
      "label": "Section Description",
      "default": "Explore our handpicked selection of premium jewelry"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 4,
      "max": 12,
      "step": 1,
      "unit": "pc",
      "label": "Number of Products to Display",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "settings": {
        "collection_title": "Featured Collection",
        "collection_description": "Explore our handpicked selection of premium jewelry"
      }
    }
  ]
}
{% endschema %}